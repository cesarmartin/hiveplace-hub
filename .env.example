# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (swappable: sqlite for dev, postgres for prod)
DATABASE_URL="file:./dev.db"

# Webhook HMAC secrets (one per provider)
PLUGGY_WEBHOOK_SECRET=dev-pluggy-secret-change-me
BELVO_WEBHOOK_SECRET=dev-belvo-secret-change-me

# API auth (simple API key for internal consumers)
API_KEY=dev-api-key-change-me

# Mock providers (used by sync pull endpoint)
PLUGGY_MOCK_URL=http://pluggy-mock:4001
BELVO_MOCK_URL=http://belvo-mock:4002
